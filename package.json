{
  "name": "qingframe",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run --cwd apps/web build && bun run --cwd apps/server dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "build": "bun run --cwd apps/web build && bun run --cwd apps/server build",
    "start": "bun run --cwd apps/server start"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  }
}
